<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Auguri di Buon Compleanno</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #0a0a0a;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-family: 'Georgia', serif;
  }

  .scene {
    position: relative;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Sfondo sfumato animato */
  .bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 60%, #2a0a1a 0%, #0a0a0a 70%);
    animation: bgPulse 6s ease-in-out infinite;
  }

  @keyframes bgPulse {
    0%, 100% { background: radial-gradient(ellipse at 50% 60%, #2a0a1a 0%, #0a0a0a 70%); }
    50% { background: radial-gradient(ellipse at 50% 60%, #3d1020 0%, #0a0a0a 70%); }
  }

  /* Bagliore dietro i fiori */
  .glow {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,180,100,0.18) 0%, transparent 70%);
    animation: glowPulse 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glowPulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.15); opacity: 1; }
  }

  /* Contenitore immagine */
  .flower-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .flower-img {
    width: min(420px, 85vw);
    height: auto;
    border-radius: 8px;
    animation: floatBouquet 5s ease-in-out infinite;
    filter: drop-shadow(0 20px 60px rgba(255,150,80,0.5));
    transform-origin: center bottom;
  }

  @keyframes floatBouquet {
    0%   { transform: translateY(0px) rotate(-1deg); filter: drop-shadow(0 20px 60px rgba(255,150,80,0.5)) brightness(1); }
    25%  { transform: translateY(-12px) rotate(0.5deg); filter: drop-shadow(0 30px 80px rgba(255,180,100,0.7)) brightness(1.08); }
    50%  { transform: translateY(-18px) rotate(1deg); filter: drop-shadow(0 35px 90px rgba(255,200,120,0.8)) brightness(1.12); }
    75%  { transform: translateY(-8px) rotate(-0.3deg); filter: drop-shadow(0 25px 70px rgba(255,160,90,0.6)) brightness(1.05); }
    100% { transform: translateY(0px) rotate(-1deg); filter: drop-shadow(0 20px 60px rgba(255,150,80,0.5)) brightness(1); }
  }

  /* Petali che cadono */
  .petal {
    position: absolute;
    width: 10px;
    height: 14px;
    border-radius: 50% 50% 50% 0;
    opacity: 0;
    animation: petalFall linear infinite;
    pointer-events: none;
    z-index: 1;
  }

  @keyframes petalFall {
    0%   { opacity: 0; transform: translateY(-40px) rotate(0deg) scale(0.8); }
    10%  { opacity: 0.8; }
    90%  { opacity: 0.5; }
    100% { opacity: 0; transform: translateY(110vh) rotate(720deg) scale(1.2); }
  }

  /* Scintille luminose */
  .spark {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #fff;
    opacity: 0;
    animation: sparkle ease-in-out infinite;
    pointer-events: none;
    z-index: 3;
  }

  @keyframes sparkle {
    0%, 100% { opacity: 0; transform: scale(0); }
    50% { opacity: 1; transform: scale(1.5); }
  }

  /* Testo auguri */
  .message {
    text-align: center;
    z-index: 4;
    animation: fadeInUp 1.5s ease forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .message h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: #fff;
    letter-spacing: 0.05em;
    text-shadow: 0 0 30px rgba(255,200,100,0.8), 0 0 60px rgba(255,150,50,0.5);
    animation: textGlow 4s ease-in-out infinite;
    font-weight: 300;
  }

  @keyframes textGlow {
    0%, 100% { text-shadow: 0 0 30px rgba(255,200,100,0.8), 0 0 60px rgba(255,150,50,0.5); }
    50% { text-shadow: 0 0 50px rgba(255,220,130,1), 0 0 100px rgba(255,180,80,0.8), 0 0 140px rgba(255,120,50,0.4); }
  }

  .message p {
    margin-top: 14px;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: rgba(255,220,180,0.85);
    letter-spacing: 0.15em;
    font-style: italic;
    animation: textGlow 4s ease-in-out infinite 1s;
  }

  /* Vignetta */
  .vignette {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
    z-index: 5;
  }
</style>
</head>
<body>

<div class="scene">
  <div class="bg"></div>
  <div class="glow"></div>

  <!-- Petali cadenti generati via JS -->

  <div class="flower-wrap">
    <img class="flower-img" src="data:image/avif;base64," alt="Mazzo di fiori">
    <div class="message">
      <h1>Buon Compleanno</h1>
      <p>non dirmi che volevi i soliti girasoli</p>
    </div>
  </div>

  <div class="vignette"></div>
</div>

<script>
// Petali cadenti
const colors = ['#ff6b8a','#ffb347','#ff8fab','#ffd6e0','#ffcba4','#ff4d79','#ffa07a'];
const scene = document.querySelector('.scene');

for(let i = 0; i < 28; i++) {
  const petal = document.createElement('div');
  petal.className = 'petal';
  const color = colors[Math.floor(Math.random() * colors.length)];
  petal.style.cssText = `
    background: ${color};
    left: ${Math.random() * 100}vw;
    top: ${-20 + Math.random() * -80}px;
    width: ${8 + Math.random() * 10}px;
    height: ${10 + Math.random() * 14}px;
    animation-duration: ${6 + Math.random() * 10}s;
    animation-delay: ${Math.random() * 12}s;
    transform: rotate(${Math.random() * 360}deg);
    opacity: 0;
  `;
  scene.appendChild(petal);
}

// Scintille
for(let i = 0; i < 18; i++) {
  const spark = document.createElement('div');
  spark.className = 'spark';
  const size = 2 + Math.random() * 5;
  spark.style.cssText = `
    left: ${20 + Math.random() * 60}vw;
    top: ${10 + Math.random() * 80}vh;
    width: ${size}px;
    height: ${size}px;
    background: ${Math.random() > 0.5 ? '#fff' : '#ffe066'};
    box-shadow: 0 0 ${size * 3}px ${Math.random() > 0.5 ? '#fff' : '#ffcc44'};
    animation-duration: ${2 + Math.random() * 3}s;
    animation-delay: ${Math.random() * 4}s;
  `;
  scene.appendChild(spark);
}
</script>
</body>
</html>
